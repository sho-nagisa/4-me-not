# Copy this file to .env for local development.

# PostgreSQL settings used by Docker Compose.
POSTGRES_USER=forme_not
POSTGRES_PASSWORD=forme_not
POSTGRES_DB=forme_not
POSTGRES_PORT=5432

# Host-side backend and Alembic use this URL.
DATABASE_URL=postgresql://forme_not:forme_not@localhost:5432/forme_not

# Local app defaults.
# APP_ENV defaults to production. Uncomment APP_ENV=dev only for local
# development, where unauthenticated requests may use DEFAULT_ACCOUNT_ID.
# APP_ENV=dev
# DEFAULT_ACCOUNT_ID=00000000-0000-0000-0000-000000000001
# DEFAULT_ACCOUNT_EMAIL=debug@example.local
# Required outside dev. Generate a unique secret for each environment.
AUTH_SECRET_KEY=
AUTH_SESSION_TTL_SECONDS=2592000
# AUTH_COOKIE_SECURE defaults to true outside dev and false in dev.
# AUTH_COOKIE_SECURE=false
# Login throttling is DB-backed and keyed on both email and client IP within the
# rolling window. Set a limit to 0 to disable that dimension.
AUTH_LOGIN_RATE_LIMIT_MAX_FAILURES=5
AUTH_LOGIN_RATE_LIMIT_IP_MAX_FAILURES=20
AUTH_LOGIN_RATE_LIMIT_WINDOW_SECONDS=300

# Optional. If OPENAI_API_KEY is empty, search uses the local fallback embedding.
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
SEARCH_FALLBACK_EMBEDDING_DIM=384

# Docker Compose port bindings.
BACKEND_PORT=8000
FRONTEND_PORT=5173
